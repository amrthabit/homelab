#!/usr/sbin/nft -f
# /etc/nftables.conf — generated by homelab webui from state.json
flush ruleset

table inet filter {
    chain input {
        type filter hook input priority filter; policy drop;

        iif "lo" accept comment "loopback"
        ct state established,related accept comment "established conns"
        ct state invalid drop comment "invalid"

        icmp type echo-request accept comment "ping"
        icmpv6 type { echo-request, nd-neighbor-solicit, nd-neighbor-advert, nd-router-advert, nd-router-solicit } accept

        tcp dport 22 ip saddr 192.168.2.0/24 accept comment "SSH from VLAN 10"
        tcp dport 22 ip saddr 192.168.30.0/24 accept comment "SSH from VLAN 30"

        tcp dport 80 ip saddr 192.168.2.0/24 accept comment "Web UI from VLAN 10"
        tcp dport 80 ip saddr 192.168.30.0/24 accept comment "Web UI from VLAN 30"

        udp dport 67 iifname { "eth0.20", "eth0.30" } accept comment "DHCP server"
        udp dport 53 iifname { "eth0.20", "eth0.30" } accept comment "DNS"
        tcp dport 53 iifname { "eth0.20", "eth0.30" } accept comment "DNS"
    }

    chain forward {
        type filter hook forward priority filter; policy drop;

        ct state established,related accept comment "established conns"
        ct state invalid drop comment "invalid"

        iifname "eth0.30" oifname "eth0" accept comment "trusted → internet"
        iifname "eth0.30" oifname "eth0.20" accept comment "trusted → IoT"

        {% if state.vlan10_to_vlan30 %}
        iifname "eth0" oifname "eth0.30" accept comment "Gigahub → trusted services [TOGGLE]"
        {% endif %}

        {% if state.vlan20_wan %}
        iifname "eth0.20" oifname "eth0" accept comment "IoT → internet [TOGGLE]"
        {% endif %}
    }

    chain output {
        type filter hook output priority filter; policy accept;
    }
}

table ip nat {
    chain postrouting {
        type nat hook postrouting priority srcnat;

        oifname "eth0" ip saddr 192.168.20.0/24 masquerade comment "NAT IoT → WAN"
        oifname "eth0" ip saddr 192.168.30.0/24 masquerade comment "NAT trusted → WAN"
    }
}
